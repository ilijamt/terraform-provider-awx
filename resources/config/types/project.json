{
  "endpoint": "/api/v2/projects/",
  "name": "Project",
  "type_name": "project",
  "id_key": "id",
  "enabled": true,
  "has_object_roles": true,
  "remove_fields_data_source": [
    "custom_virtualenv",
    "status",
    "scm_revision"
  ],
  "remove_fields_resource": [
    "custom_virtualenv",
    "status",
    "scm_revision"
  ],
  "search_fields": [
    {
      "url_suffix": "%d/",
      "name": "by_id",
      "fields": [
        {
          "name": "id"
        }
      ]
    }
  ],
  "wait_lifecycle": {
    "wait_attribute": "wait_for_sync",
    "wait_description": "If true, wait for AWX to finish the SCM update kicked off on create or update before returning. Configure the maximum wait via the timeouts block.",
    "endpoint_suffix": "%d/",
    "status_field": "status",
    "success_values": [
      "successful",
      "ok",
      "never updated"
    ],
    "failure_values": [
      "failed",
      "error",
      "canceled"
    ],
    "default_timeout": "5m",
    "poll_interval": "5s"
  }
}
